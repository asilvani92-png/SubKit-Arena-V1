{
  "name": "Match",
  "type": "object",
  "description": "A Flicker Club Match Night football match. Replaces the old turn-based match shape. The actual simulation state is held in match_events; this row is the metadata + score/clock snapshot.",
  "properties": {
    "home_user_id": {
      "type": "string",
      "description": "Auth user id of the home manager"
    },
    "away_user_id": {
      "type": "string",
      "description": "Auth user id of the away manager. For AI matches, this is the user id of the AI owner (a 'house' user) or null"
    },
    "home_collection_id": {
      "type": "string",
      "description": "UserCollection id for the home team"
    },
    "away_collection_id": {
      "type": "string",
      "description": "UserCollection id for the away team. For AI matches, references a house-team collection."
    },
    "home_team_name": {
      "type": "string"
    },
    "away_team_name": {
      "type": "string"
    },
    "match_type": {
      "type": "string",
      "enum": ["friendly", "ranked", "cup", "league", "ai"],
      "default": "friendly"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "active", "half_time", "completed", "abandoned"],
      "default": "pending"
    },
    "is_ai_match": {
      "type": "boolean",
      "default": false
    },
    "home_formation": {
      "type": "string",
      "description": "Formation key e.g. 4-4-2"
    },
    "away_formation": {
      "type": "string"
    },
    "home_tactic": {
      "type": "string",
      "description": "Tactical preset: balanced, attacking, defensive, counter, possession, direct",
      "default": "balanced"
    },
    "away_tactic": {
      "type": "string",
      "default": "balanced"
    },
    "home_score": {
      "type": "number",
      "default": 0
    },
    "away_score": {
      "type": "number",
      "default": 0
    },
    "current_minute": {
      "type": "number",
      "default": 0,
      "description": "0 to 90 (plus extra time for cups)"
    },
    "home_ap_remaining": {
      "type": "number",
      "default": 6
    },
    "away_ap_remaining": {
      "type": "number",
      "default": 6
    },
    "home_active_shout": {
      "type": "string",
      "description": "Currently active tactical shout for the home team, or null"
    },
    "home_shout_expires_minute": {
      "type": "number"
    },
    "away_active_shout": {
      "type": "string"
    },
    "away_shout_expires_minute": {
      "type": "number"
    },
    "home_momentum": {
      "type": "number",
      "default": 0,
      "description": "Hidden momentum value -100 to +100 (positive = home)"
    },
    "possession": {
      "type": "string",
      "enum": ["home", "away", "none"],
      "default": "home"
    },
    "ball_zone": {
      "type": "string",
      "description": "Current zone on the 4x3 grid — DEF_L/DEF_C/DEF_R/MID_L/MID_C/MID_R/ATT_L/ATT_C/ATT_R/BOX_L/BOX_C/BOX_R"
    },
    "speed": {
      "type": "string",
      "enum": ["slow", "normal", "fast", "instant"],
      "default": "normal"
    },
    "is_async": {
      "type": "boolean",
      "default": false
    },
    "winner_user_id": {
      "type": "string"
    },
    "man_of_the_match_player_id": {
      "type": "string",
      "description": "PlayerCard id"
    },
    "home_subs_used": {
      "type": "number",
      "default": 0,
      "description": "Max 3"
    },
    "away_subs_used": {
      "type": "number",
      "default": 0
    },
    "action_log": {
      "type": "array",
      "description": "Append-only record of user actions taken during the match (tactical shouts, demand shot, sub, etc.)",
      "items": {
        "type": "object",
        "properties": {
          "minute": { "type": "number" },
          "team": { "type": "string", "enum": ["home", "away"] },
          "action_type": { "type": "string" },
          "detail": { "type": "object" },
          "ap_cost": { "type": "number" },
          "timestamp": { "type": "string" }
        }
      }
    },
    "board_state": {
      "type": "object",
      "description": "Final or current snapshot of pitch state used for replay and persistence",
      "properties": {
        "minute": { "type": "number" },
        "home_positions": { "type": "array", "items": { "type": "object" } },
        "away_positions": { "type": "array", "items": { "type": "object" } },
        "ball_position": { "type": "object" }
      }
    },
    "stats": {
      "type": "object",
      "description": "Match statistics accumulated across the simulation",
      "properties": {
        "home_possession_pct": { "type": "number" },
        "home_shots": { "type": "number" },
        "home_shots_on_target": { "type": "number" },
        "home_fouls": { "type": "number" },
        "home_corners": { "type": "number" },
        "home_yellow_cards": { "type": "number" },
        "home_red_cards": { "type": "number" },
        "away_possession_pct": { "type": "number" },
        "away_shots": { "type": "number" },
        "away_shots_on_target": { "type": "number" },
        "away_fouls": { "type": "number" },
        "away_corners": { "type": "number" },
        "away_yellow_cards": { "type": "number" },
        "away_red_cards": { "type": "number" }
      }
    },
    "started_at": { "type": "string" },
    "completed_at": { "type": "string" },
    "created_date": { "type": "string" }
  },
  "required": [
    "home_user_id",
    "home_collection_id",
    "match_type"
  ]
}
