{
  "name": "FlickerClub",
  "type": "object",
  "description": "A user's Flicker Club identity — the manager profile that owns manager XP, level, Elo rating, and club branding. One per user.",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "Auth user id (also primary identifier)"
    },
    "club_name": {
      "type": "string",
      "description": "Flicker Club name e.g. 'Goodison Flickers'"
    },
    "club_badge_url": {
      "type": "string"
    },
    "club_motto": {
      "type": "string"
    },
    "home_ground_name": {
      "type": "string"
    },
    "manager_xp": {
      "type": "number",
      "default": 0
    },
    "manager_level": {
      "type": "number",
      "default": 1
    },
    "elo_rating": {
      "type": "number",
      "default": 1000
    },
    "matches_played": {
      "type": "number",
      "default": 0
    },
    "wins": { "type": "number", "default": 0 },
    "draws": { "type": "number", "default": 0 },
    "losses": { "type": "number", "default": 0 },
    "goals_for": { "type": "number", "default": 0 },
    "goals_against": { "type": "number", "default": 0 },
    "created_at": { "type": "string" }
  },
  "required": ["user_id"]
}
