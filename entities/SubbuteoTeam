{
  "name": "SubbuteoTeam",
  "type": "object",
  "description": "A Subbuteo reference team in the SubKit catalogue. Base_rating drives stat generation for Flicker Club Match Night.",
  "properties": {
    "name": {
      "type": "string",
      "description": "Team name"
    },
    "ref_number": {
      "type": "string",
      "description": "Official Subbuteo catalogue reference number"
    },
    "era": {
      "type": "string",
      "enum": [
        "1966-1975",
        "1976-1985",
        "1986-1995",
        "1996-2005",
        "Modern 2000s",
        "Modern 2010s",
        "Modern 2020s",
        "Special Edition",
        "Unknown"
      ],
      "description": "Production era — also drives stat-generation era modifier"
    },
    "country": {
      "type": "string",
      "description": "Country / nation the team represents"
    },
    "kit_description": {
      "type": "string",
      "description": "Brief description of the kit colours and style"
    },
    "primary_colour": {
      "type": "string",
      "description": "Primary kit colour (CSS colour string) — used for home dot colour"
    },
    "secondary_colour": {
      "type": "string",
      "description": "Secondary kit colour (CSS colour string) — used for away dot colour / ring"
    },
    "player_count": {
      "type": "number",
      "description": "Number of outfield players + goalkeeper in this set",
      "default": 11
    },
    "rarity": {
      "type": "string",
      "enum": [
        "Common",
        "Uncommon",
        "Rare",
        "Ultra Rare",
        "Legend"
      ],
      "default": "Common",
      "description": "Rarity tier — also drives in-match stat bonuses"
    },
    "base_rating": {
      "type": "number",
      "description": "Admin-set base rating (1-99) reflecting the real-world quality of the team. Drives stat generation.",
      "default": 60
    },
    "market_value_gbp": {
      "type": "number",
      "description": "Current estimated market value in GBP (used for in-game boost)"
    },
    "boost_modifier": {
      "type": "number",
      "description": "In-game power boost multiplier (1.0 = baseline, admin-set)",
      "default": 1.0
    },
    "image_url": {
      "type": "string",
      "description": "Reference image of the team/kit"
    },
    "brand": {
      "type": "string",
      "enum": [
        "Subbuteo",
        "Zeugo",
        "Astrobase",
        "Newfooty",
        "Top Spin",
        "Other"
      ],
      "default": "Subbuteo"
    },
    "is_house_team": {
      "type": "boolean",
      "default": false,
      "description": "If true, this is a classic reference used as an AI opponent. Users do not need to own it to play against it."
    },
    "ai_difficulty_tier": {
      "type": "number",
      "description": "For house teams: 1=easy, 2=medium, 3=hard. Used to match opponents to manager level.",
      "default": 1
    },
    "notes": {
      "type": "string",
      "description": "Admin notes / provenance details"
    },
    "is_published": {
      "type": "boolean",
      "default": true,
      "description": "Visible in the catalogue to users"
    }
  },
  "required": [
    "name",
    "rarity"
  ]
}
